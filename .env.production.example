# StoryForge 生产环境配置模板。
#
# docker-compose.prod.yml 会先加载本模板以支持本地 config 验证。
# 复制为 .env.production 并填入真实值；真实文件存在时会覆盖本模板。请勿提交真实文件。
# 与 .env.example 的关键差异已用 ## CHANGE: 标注。

STORYFORGE_ENV=production

## CHANGE: 指向生产 Postgres
DATABASE_URL=postgresql+psycopg://storyforge:CHANGE_ME@postgres:5432/storyforge

## CHANGE: 指向生产 Redis
REDIS_URL=redis://redis:6379/0

## CHANGE: 指向生产对象存储（建议使用云上 S3 而非自建 MinIO）
S3_ENDPOINT=https://s3.your-region.amazonaws.com
S3_REGION=your-region
S3_BUCKET=storyforge-prod
S3_ACCESS_KEY=example-production-s3-access-key-change-before-use
S3_SECRET_KEY=example-production-s3-secret-change-before-use

API_BASE_URL=https://api.storyforge.example.com
STORYFORGE_API_BASE_URL=https://api.storyforge.example.com

## CHANGE: 必须使用至少 32 字节的随机字符串。生产环境绝不可保留 local-dev-key。
STORYFORGE_API_KEY=example-production-api-key-32-bytes-minimum

## CHANGE: 必须配置非空 JWT 密钥（推荐 64 字节随机串）。
STORYFORGE_JWT_SECRET=example-production-jwt-secret-64-bytes-minimum-change-before-use
STORYFORGE_JWT_EXPIRY_SECONDS=3600

## CHANGE: 限定真实前端域名
STORYFORGE_CORS_ORIGINS=https://app.storyforge.example.com
WEB_BASE_URL=https://app.storyforge.example.com

WORKFLOW_RUNTIME_MODE=production
WORKFLOW_CHECKPOINT_BACKEND=postgres
STORYFORGE_WORKFLOW_SQLITE_PATH=/app/.runtime/workflow-runtime.sqlite3

# 真实 LLM/Embedding/Reranker 接入 —— 至少配置 OpenAI 兼容 Provider。
STORYFORGE_LLM_PROVIDER=openai
STORYFORGE_LLM_MODEL=gpt-4o-mini
STORYFORGE_LLM_API_BASE_URL=https://api.openai.com/v1
STORYFORGE_LLM_BASE_URL=https://api.openai.com/v1
STORYFORGE_LLM_API_KEY=CHANGE_ME_OPENAI_KEY
STORYFORGE_LLM_TEMPERATURE=0.7
STORYFORGE_LLM_TIMEOUT_SECONDS=60
STORYFORGE_LLM_MAX_RETRIES=2

STORYFORGE_EMBEDDING_PROVIDER=openai
STORYFORGE_EMBEDDING_MODEL=text-embedding-3-small
STORYFORGE_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
STORYFORGE_EMBEDDING_API_KEY=CHANGE_ME_OPENAI_KEY
STORYFORGE_EMBEDDING_DIMENSIONS=1536

STORYFORGE_RERANKER_PROVIDER=cohere
STORYFORGE_RERANKER_MODEL=rerank-multilingual-v3.0
STORYFORGE_RERANKER_API_BASE_URL=https://api.cohere.ai/v1
STORYFORGE_RERANKER_API_KEY=CHANGE_ME_COHERE_KEY
STORYFORGE_RAG_TOP_K=8
STORYFORGE_RAG_CONTEXT_TOKEN_BUDGET=6000
STORYFORGE_MODEL_RUN_LOG_LEVEL=summary

## CHANGE: 配置真实 Sentry DSN
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.05

## 容器自动迁移开关（默认 1，留作显式控制点）
STORYFORGE_AUTO_MIGRATE=1
STORYFORGE_MIGRATION_TIMEOUT=180
WORKERS=4
