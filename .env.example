STORYFORGE_ENV=local
DATABASE_URL=postgresql+psycopg://storyforge:storyforge@127.0.0.1:55432/storyforge
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=storyforge
S3_ACCESS_KEY=storyforge
S3_SECRET_KEY=storyforge-dev-only
API_BASE_URL=http://localhost:8000
STORYFORGE_API_BASE_URL=http://localhost:8000
STORYFORGE_API_KEY=local-dev-key
STORYFORGE_JWT_SECRET=
STORYFORGE_JWT_EXPIRY_SECONDS=3600
STORYFORGE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEB_BASE_URL=http://localhost:3000
WORKFLOW_RUNTIME_MODE=local
WORKFLOW_CHECKPOINT_BACKEND=sqlite
STORYFORGE_WORKFLOW_SQLITE_PATH=apps/workflow/.runtime/workflow-runtime.sqlite3

# Phase 5 真实 AI/RAG 配置：默认走 deterministic/local/disabled，密钥字段留空也可直接本地启动。
STORYFORGE_LLM_PROVIDER=deterministic
STORYFORGE_LLM_MODEL=storyforge-deterministic-writer
STORYFORGE_LLM_API_BASE_URL=http://localhost:8000/mock-llm/v1
STORYFORGE_LLM_BASE_URL=https://api.openai.com/v1
STORYFORGE_LLM_API_KEY=
STORYFORGE_LLM_TEMPERATURE=0.7
STORYFORGE_LLM_TIMEOUT_SECONDS=60
STORYFORGE_LLM_MAX_RETRIES=2

STORYFORGE_EMBEDDING_PROVIDER=local
STORYFORGE_EMBEDDING_MODEL=storyforge-fake-embedding
STORYFORGE_EMBEDDING_API_BASE_URL=http://localhost:8000/mock-embedding/v1
STORYFORGE_EMBEDDING_API_KEY=
STORYFORGE_EMBEDDING_DIMENSIONS=0

STORYFORGE_RERANKER_PROVIDER=disabled
STORYFORGE_RERANKER_MODEL=disabled
STORYFORGE_RERANKER_API_BASE_URL=http://localhost:8000/mock-reranker/v1
STORYFORGE_RERANKER_API_KEY=
STORYFORGE_RAG_TOP_K=8
STORYFORGE_RAG_CONTEXT_TOKEN_BUDGET=6000
STORYFORGE_MODEL_RUN_LOG_LEVEL=summary

# Sentry 错误追踪
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1