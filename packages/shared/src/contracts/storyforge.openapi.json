{
  "components": {
    "schemas": {
      "AssetCreate": {
        "description": "创建资产时由调用方提供的业务载荷。",
        "properties": {
          "asset_type": {
            "maxLength": 80,
            "minLength": 1,
            "title": "Asset Type",
            "type": "string"
          },
          "book_id": {
            "exclusiveMinimum": 0.0,
            "title": "Book Id",
            "type": "integer"
          },
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "scene_id": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "default": "active",
            "maxLength": 50,
            "minLength": 1,
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "book_id",
          "asset_type",
          "name"
        ],
        "title": "AssetCreate",
        "type": "object"
      },
      "AssetRead": {
        "description": "资产响应契约，所有路由响应都通过该结构输出。",
        "properties": {
          "asset_type": {
            "title": "Asset Type",
            "type": "string"
          },
          "book_id": {
            "title": "Book Id",
            "type": "integer"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "lineage_key": {
            "title": "Lineage Key",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "scene_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "book_id",
          "scene_id",
          "asset_type",
          "lineage_key",
          "name",
          "status",
          "payload",
          "version",
          "created_at",
          "updated_at"
        ],
        "title": "AssetRead",
        "type": "object"
      },
      "AssetUpdate": {
        "description": "更新资产会产生新版本，未提供字段沿用上一版本。",
        "properties": {
          "asset_type": {
            "anyOf": [
              {
                "maxLength": 80,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Asset Type"
          },
          "name": {
            "anyOf": [
              {
                "maxLength": 255,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "payload": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payload"
          },
          "scene_id": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "anyOf": [
              {
                "maxLength": 50,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          }
        },
        "title": "AssetUpdate",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "StoryForge API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/assets": {
      "get": {
        "description": "查询指定作品下每条资产谱系的最新版本列表。",
        "operationId": "list_assets_endpoint_api_assets_get",
        "parameters": [
          {
            "in": "query",
            "name": "book_id",
            "required": true,
            "schema": {
              "exclusiveMinimum": 0,
              "title": "Book Id",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "asset_type",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "maxLength": 80,
                  "minLength": 1,
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Asset Type"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AssetRead"
                  },
                  "title": "Response List Assets Endpoint Api Assets Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Assets Endpoint",
        "tags": [
          "资产中心"
        ]
      },
      "post": {
        "description": "创建角色、地点、风格规则等资产的首个版本。",
        "operationId": "create_asset_endpoint_api_assets_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Asset Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    },
    "/api/assets/{asset_id}": {
      "patch": {
        "description": "更新资产并创建新版本，旧版本保留在历史中。",
        "operationId": "update_asset_endpoint_api_assets__asset_id__patch",
        "parameters": [
          {
            "in": "path",
            "name": "asset_id",
            "required": true,
            "schema": {
              "title": "Asset Id",
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Update Asset Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    },
    "/api/assets/{asset_id}/history": {
      "get": {
        "description": "读取资产同一谱系的全部版本历史。",
        "operationId": "read_asset_history_endpoint_api_assets__asset_id__history_get",
        "parameters": [
          {
            "in": "path",
            "name": "asset_id",
            "required": true,
            "schema": {
              "title": "Asset Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AssetRead"
                  },
                  "title": "Response Read Asset History Endpoint Api Assets  Asset Id  History Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read Asset History Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    }
  }
}
