{
  "components": {
    "schemas": {
      "AssetCreate": {
        "description": "创建资产时由调用方提供的业务载荷。",
        "properties": {
          "asset_type": {
            "maxLength": 80,
            "minLength": 1,
            "title": "Asset Type",
            "type": "string"
          },
          "book_id": {
            "exclusiveMinimum": 0.0,
            "title": "Book Id",
            "type": "integer"
          },
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "scene_id": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "default": "active",
            "maxLength": 50,
            "minLength": 1,
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "book_id",
          "asset_type",
          "name"
        ],
        "title": "AssetCreate",
        "type": "object"
      },
      "AssetRead": {
        "description": "资产响应契约，所有路由响应都通过该结构输出。",
        "properties": {
          "asset_type": {
            "title": "Asset Type",
            "type": "string"
          },
          "book_id": {
            "title": "Book Id",
            "type": "integer"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "lineage_key": {
            "title": "Lineage Key",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "scene_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "book_id",
          "scene_id",
          "asset_type",
          "lineage_key",
          "name",
          "status",
          "payload",
          "version",
          "created_at",
          "updated_at"
        ],
        "title": "AssetRead",
        "type": "object"
      },
      "AssetUpdate": {
        "description": "更新资产会产生新版本，未提供字段沿用上一版本。",
        "properties": {
          "asset_type": {
            "anyOf": [
              {
                "maxLength": 80,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Asset Type"
          },
          "name": {
            "anyOf": [
              {
                "maxLength": 255,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "payload": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payload"
          },
          "scene_id": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "anyOf": [
              {
                "maxLength": 50,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          }
        },
        "title": "AssetUpdate",
        "type": "object"
      },
      "BudgetStatistics": {
        "description": "预算统计说明上下文包是否发生检索片段裁剪。",
        "properties": {
          "reserved_tokens": {
            "title": "Reserved Tokens",
            "type": "integer"
          },
          "retrieval_tokens": {
            "title": "Retrieval Tokens",
            "type": "integer"
          },
          "token_budget": {
            "title": "Token Budget",
            "type": "integer"
          },
          "truncated": {
            "title": "Truncated",
            "type": "boolean"
          },
          "used_tokens": {
            "title": "Used Tokens",
            "type": "integer"
          }
        },
        "required": [
          "token_budget",
          "used_tokens",
          "reserved_tokens",
          "retrieval_tokens",
          "truncated"
        ],
        "title": "BudgetStatistics",
        "type": "object"
      },
      "ChapterApprovalCreate": {
        "description": "章节批准时回写下一章需要继承的连续性事实。",
        "properties": {
          "chapter_id": {
            "exclusiveMinimum": 0.0,
            "title": "Chapter Id",
            "type": "integer"
          },
          "character_state_changes": {
            "additionalProperties": true,
            "title": "Character State Changes",
            "type": "object"
          },
          "foreshadowing_changes": {
            "additionalProperties": true,
            "title": "Foreshadowing Changes",
            "type": "object"
          },
          "next_chapter_constraints": {
            "items": {
              "type": "string"
            },
            "title": "Next Chapter Constraints",
            "type": "array"
          },
          "previous_chapter_summary": {
            "minLength": 1,
            "title": "Previous Chapter Summary",
            "type": "string"
          },
          "style_drift": {
            "minLength": 1,
            "title": "Style Drift",
            "type": "string"
          }
        },
        "required": [
          "chapter_id",
          "previous_chapter_summary",
          "style_drift"
        ],
        "title": "ChapterApprovalCreate",
        "type": "object"
      },
      "ChapterApprovalRead": {
        "description": "章节批准响应包含本次写入的连续性记录集合。",
        "properties": {
          "book_id": {
            "title": "Book Id",
            "type": "integer"
          },
          "chapter_id": {
            "title": "Chapter Id",
            "type": "integer"
          },
          "record_count": {
            "title": "Record Count",
            "type": "integer"
          },
          "records": {
            "items": {
              "$ref": "#/components/schemas/ContinuityRecordRead"
            },
            "title": "Records",
            "type": "array"
          }
        },
        "required": [
          "chapter_id",
          "book_id",
          "record_count",
          "records"
        ],
        "title": "ChapterApprovalRead",
        "type": "object"
      },
      "ContinuityRecordRead": {
        "description": "连续性记录响应契约，保持数据库真相源可追溯。",
        "properties": {
          "book_id": {
            "title": "Book Id",
            "type": "integer"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "record_type": {
            "title": "Record Type",
            "type": "string"
          },
          "scene_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scene Id"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "subject": {
            "title": "Subject",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "book_id",
          "scene_id",
          "record_type",
          "subject",
          "status",
          "payload",
          "version",
          "created_at",
          "updated_at"
        ],
        "title": "ContinuityRecordRead",
        "type": "object"
      },
      "EvidenceLinkRead": {
        "description": "证据链接响应用于追溯上下文来源。",
        "properties": {
          "asset_id": {
            "title": "Asset Id",
            "type": "integer"
          },
          "evidence_type": {
            "title": "Evidence Type",
            "type": "string"
          },
          "rationale": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rationale"
          },
          "source_ref": {
            "title": "Source Ref",
            "type": "string"
          }
        },
        "required": [
          "asset_id",
          "evidence_type",
          "source_ref"
        ],
        "title": "EvidenceLinkRead",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ScenePacketCreate": {
        "description": "组装场景上下文包所需的显式输入。",
        "properties": {
          "active_asset_ids": {
            "items": {
              "type": "integer"
            },
            "minItems": 1,
            "title": "Active Asset Ids",
            "type": "array"
          },
          "book_id": {
            "exclusiveMinimum": 0.0,
            "title": "Book Id",
            "type": "integer"
          },
          "chapter_id": {
            "exclusiveMinimum": 0.0,
            "title": "Chapter Id",
            "type": "integer"
          },
          "retrieval_snippets": {
            "items": {
              "type": "string"
            },
            "title": "Retrieval Snippets",
            "type": "array"
          },
          "scene_goal": {
            "minLength": 1,
            "title": "Scene Goal",
            "type": "string"
          },
          "token_budget": {
            "exclusiveMinimum": 0.0,
            "title": "Token Budget",
            "type": "integer"
          },
          "user_intent": {
            "default": "",
            "maxLength": 2000,
            "title": "User Intent",
            "type": "string"
          }
        },
        "required": [
          "book_id",
          "chapter_id",
          "scene_goal",
          "active_asset_ids",
          "token_budget"
        ],
        "title": "ScenePacketCreate",
        "type": "object"
      },
      "ScenePacketRead": {
        "description": "Scene Packet 响应契约，固定槽位保存在 packet 字段中。",
        "properties": {
          "budget_statistics": {
            "$ref": "#/components/schemas/BudgetStatistics"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "evidence_links": {
            "items": {
              "$ref": "#/components/schemas/EvidenceLinkRead"
            },
            "title": "Evidence Links",
            "type": "array"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "packet": {
            "additionalProperties": true,
            "title": "Packet",
            "type": "object"
          },
          "scene_id": {
            "title": "Scene Id",
            "type": "integer"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "scene_id",
          "status",
          "packet",
          "budget_statistics",
          "evidence_links",
          "version",
          "created_at",
          "updated_at"
        ],
        "title": "ScenePacketRead",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "StoryForge API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/assets": {
      "get": {
        "description": "查询指定作品下每条资产谱系的最新版本列表。",
        "operationId": "list_assets_endpoint_api_assets_get",
        "parameters": [
          {
            "in": "query",
            "name": "book_id",
            "required": true,
            "schema": {
              "exclusiveMinimum": 0,
              "title": "Book Id",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "asset_type",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "maxLength": 80,
                  "minLength": 1,
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Asset Type"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AssetRead"
                  },
                  "title": "Response List Assets Endpoint Api Assets Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Assets Endpoint",
        "tags": [
          "资产中心"
        ]
      },
      "post": {
        "description": "创建角色、地点、风格规则等资产的首个版本。",
        "operationId": "create_asset_endpoint_api_assets_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Asset Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    },
    "/api/assets/{asset_id}": {
      "patch": {
        "description": "更新资产并创建新版本，旧版本保留在历史中。",
        "operationId": "update_asset_endpoint_api_assets__asset_id__patch",
        "parameters": [
          {
            "in": "path",
            "name": "asset_id",
            "required": true,
            "schema": {
              "title": "Asset Id",
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Update Asset Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    },
    "/api/assets/{asset_id}/history": {
      "get": {
        "description": "读取资产同一谱系的全部版本历史。",
        "operationId": "read_asset_history_endpoint_api_assets__asset_id__history_get",
        "parameters": [
          {
            "in": "path",
            "name": "asset_id",
            "required": true,
            "schema": {
              "title": "Asset Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AssetRead"
                  },
                  "title": "Response Read Asset History Endpoint Api Assets  Asset Id  History Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Read Asset History Endpoint",
        "tags": [
          "资产中心"
        ]
      }
    },
    "/api/continuity/chapter-approval": {
      "post": {
        "description": "记录章节批准后的摘要、状态变化、伏笔变化和继承约束。",
        "operationId": "approve_chapter_endpoint_api_continuity_chapter_approval_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChapterApprovalCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChapterApprovalRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Approve Chapter Endpoint",
        "tags": [
          "章节连续性"
        ]
      }
    },
    "/api/scene-packets": {
      "post": {
        "description": "为章节首个场景组装固定槽位 Scene Packet 并持久化。",
        "operationId": "create_scene_packet_endpoint_api_scene_packets_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScenePacketCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScenePacketRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Scene Packet Endpoint",
        "tags": [
          "场景上下文包"
        ]
      }
    }
  }
}
