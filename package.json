{
  "name": "storyforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "verify": "pnpm run verify:local",
    "verify:local": "node scripts/verify-local.mjs",
    "verify:fast": "pnpm run lint && pnpm run check:drift",
    "check:drift": "node scripts/check-openapi-drift.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "dev": "pnpm desktop:dev",
    "dev:maintenance": "node scripts/dev-start.mjs",
    "dev:api": "node scripts/dev-start.mjs --api-only",
    "desktop:dev": "pnpm --filter @storyforge/desktop dev",
    "desktop:build": "pnpm --filter @storyforge/desktop build",
    "test": "pnpm run test:desktop && pnpm run test:shared && pnpm run test:api && pnpm run test:workflow",
    "test:desktop": "npm --prefix apps/desktop run verify",
    "test:shared": "pnpm --filter @storyforge/shared test",
    "test:api": "cd apps/api && uv run pytest",
    "test:workflow": "cd apps/workflow && uv run pytest",
    "e2e": "node scripts/run-e2e.mjs",
    "smoke:sidecar": "node scripts/sidecar-smoke.mjs",
    "smoke:sidecar:packaged": "node scripts/sidecar-smoke.mjs --packaged",
    "golden": "node scripts/run-golden.mjs",
    "openapi": "node scripts/generate-openapi.mjs",
    "lint": "eslint . && prettier --check \"apps/desktop/frontend/src/**/*.{ts,tsx}\" \"packages/shared/src/**/*.ts\" \"scripts/**/*.mjs\"",
    "lint:fix": "eslint . --fix && prettier --write \"apps/desktop/frontend/src/**/*.{ts,tsx}\" \"packages/shared/src/**/*.ts\" \"scripts/**/*.mjs\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.0"
  }
}
